<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 60-Day Tally Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Mood Summary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTallyPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last 60 days — 0 entries"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <!-- Mood counts in two columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:id="@+id/tvTallyAngry"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😡 Angry:   0" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTallySad"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😢 Sad:     0" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTallyMeh"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😐 Meh:     0" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:id="@+id/tvTallyContent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😊 Content: 0" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTallyHappy"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😄 Happy:   0" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvTallyEnergy"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡ Avg Energy: 0.0 / 5" android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Long press an entry to delete it"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
